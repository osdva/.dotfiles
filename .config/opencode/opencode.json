{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "build": {
      "model": "opencode-go/kimi-k2.6"
    }
  },
  "enabled_providers": [
    "openai",
    "opencode-go"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "pencil": {
      "command": [
        "/tmp/.mount_pencilePtMvH/resources/app.asar.unpacked/out/mcp-server-linux-x64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}